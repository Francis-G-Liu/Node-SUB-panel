{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Debug (Attach)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "address": "localhost",
      "restart": true,
      "sourceMaps": true,
      "localRoot": "${workspaceFolder}/apps/api",
      "remoteRoot": "${workspaceFolder}/apps/api",
      "outFiles": ["${workspaceFolder}/apps/api/dist/**/*.js"],
      "preLaunchTask": "API: Start Debug",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Frontend: Chrome (Debug)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/apps/web",
      "sourceMaps": true,
      "preLaunchTask": "Web: Start Dev",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/src/*",
        "meteor:///app/*": "${webRoot}/*"
      }
    },
    {
      "name": "API: Debug Jest Current File",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/api",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "test:debug",
        "--",
        "--runInBand",
        "${file}"
      ],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
