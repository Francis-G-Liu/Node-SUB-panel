{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "API: Start Debug",
      "type": "npm",
      "script": "start:debug",
      "path": "apps/api",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting compilation in watch mode...",
          "endsPattern": "Nest application successfully started"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend"
      }
    },
    {
      "label": "Web: Start Dev",
      "type": "npm",
      "script": "dev",
      "path": "apps/web",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE v.* ready in",
          "endsPattern": "➜  Local:"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "frontend"
      }
    },
    {
      "label": "Full Stack: Dev",
      "dependsOn": ["API: Start Debug", "Web: Start Dev"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "API: Test Unit",
      "type": "npm",
      "script": "test",
      "path": "apps/api",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "test"
      }
    },
    {
      "label": "API: Test E2E",
      "type": "npm",
      "script": "test:e2e",
      "path": "apps/api",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "test"
      }
    },
    {
      "label": "Worker: Test",
      "type": "npm",
      "script": "test",
      "path": "apps/worker",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "test"
      }
    },
    {
      "label": "SDK: Test",
      "type": "npm",
      "script": "test",
      "path": "packages/sdk",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "test"
      }
    },
    {
      "label": "Monorepo: Test All",
      "type": "npm",
      "script": "test",
      "path": ".",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "test"
      }
    }
  ]
}
